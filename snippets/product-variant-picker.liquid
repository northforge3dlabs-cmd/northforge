{% comment %}
  Renders product variant-picker

  Accepts:
  - product: {Object} product object.
  - block: {Object} passing the block information.
  - product_form_id: {String} Id of the product form to which the variant picker is associated.
  Usage:
  {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id %}
{% endcomment %}
{%- unless product.has_only_default_variant -%}
  <style>
    .product-form__input--pill label[data-nf-selected] {
      outline: 3px solid #1c1c1c !important;
      outline-offset: 2px;
    }
  </style>
  <variant-selects
    id="variant-selects-{{ section.id }}"
    data-section="{{ section.id }}"
    {{ block.shopify_attributes }}
  >
    {%- for option in product.options_with_values -%}
      {%- liquid
        assign swatch_count = option.values | map: 'swatch' | compact | size
        assign picker_type = block.settings.picker_type

        if swatch_count > 0 and block.settings.swatch_shape != 'none'
          if block.settings.picker_type == 'dropdown'
            assign picker_type = 'swatch_dropdown'
          else
            assign picker_type = 'swatch'
          endif
        endif
      -%}

      {%- if option.name == 'Paint Trays' -%}
        {%- comment %}
          Paint Trays is intentionally not rendered inside variant-selects.
          Dawn 14 reads all select option[selected] elements inside variant-selects
          to build the option_values API request. Our custom tray UI doesn't use
          Shopify option value IDs, so including a select here would inject
          undefined into the request and break colour swatch selection.
          The tray configuration UI lives below, outside variant-selects.
        {%- endcomment -%}

      {%- elsif picker_type == 'swatch' -%}
        <fieldset class="js product-form__input product-form__input--swatch">
          <legend class="form__label">
            {{ option.name }}:
            <span data-selected-value>
              {{- option.selected_value -}}
            </span>
          </legend>
          {% render 'product-variant-options',
            product: product,
            option: option,
            block: block,
            picker_type: picker_type
          %}
        </fieldset>
      {%- elsif picker_type == 'button' and option.name != 'Additional Trays' -%}
        <fieldset class="js product-form__input product-form__input--pill">
          <legend class="form__label">{{ option.name }}</legend>
          {% render 'product-variant-options',
            product: product,
            option: option,
            block: block,
            picker_type: picker_type
          %}
        </fieldset>
      {%- else -%}
        <div class="product-form__input product-form__input--dropdown">
          <label class="form__label" for="Option-{{ section.id }}-{{ forloop.index0 }}">
            {{ option.name }}
          </label>
          <div class="select">
            {%- if picker_type == 'swatch_dropdown' -%}
              <span
                data-selected-value
                class="dropdown-swatch"
              >
                {% render 'swatch', swatch: option.selected_value.swatch, shape: block.settings.swatch_shape %}
              </span>
            {%- endif -%}
            <select
              id="Option-{{ section.id }}-{{ forloop.index0 }}"
              class="select__select"
              name="options[{{ option.name | escape }}]"
              form="{{ product_form_id }}"
            >
              {% render 'product-variant-options',
                product: product,
                option: option,
                block: block,
                picker_type: picker_type
              %}
            </select>
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}

    <script type="application/json" data-selected-variant>
      {{ product.selected_or_first_available_variant | json }}
    </script>
  </variant-selects>

  {%- comment %}
    Tray configuration — rendered OUTSIDE variant-selects so Dawn's HTML swap
    (triggered on colour changes) does not wipe the tray dropdowns.
  {%- endcomment -%}
  {%- assign has_paint_trays_option = false -%}
  {%- for option in product.options_with_values -%}
    {%- if option.name == 'Paint Trays' -%}
      {%- assign has_paint_trays_option = true -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if has_paint_trays_option -%}
    {%- assign tray_count = 3 -%}
    {%- for tag in product.tags -%}
      {%- if tag contains 'tray-count-' -%}
        {%- assign tray_count = tag | remove: 'tray-count-' | plus: 0 -%}
      {%- endif -%}
    {%- endfor -%}

    <div class="nf-tray-config" id="nf-tray-config-{{ section.id }}">
      <p class="form__label" style="margin-bottom:0.6rem;margin-top:2rem;">Tray Configuration</p>
      <p style="font-size:1.4rem;color:#666;margin-bottom:1.4rem;line-height:1.5;">
        Select the type for each of the {{ tray_count }} storage trays. Paint trays add $5 CAD each.
      </p>

      {%- for i in (1..tray_count) -%}
        <div class="product-form__input product-form__input--dropdown" style="margin-bottom:1rem;">
          <label class="form__label" for="nf-tray-{{ i }}-{{ section.id }}">Tray {{ i }}</label>
          <div class="select">
            <select
              id="nf-tray-{{ i }}-{{ section.id }}"
              class="select__select nf-tray-select"
              data-tray="{{ i }}"
              data-section="{{ section.id }}"
            >
              <option value="Magnet Tray">Magnet Tray</option>
              <option value="GW Tray">GW Tray</option>
              <option value="Paint Tray — Vallejo / Army Painter">Paint Tray — Vallejo / Army Painter (+$5 CAD)</option>
              <option value="Paint Tray — Citadel Paints">Paint Tray — Citadel Paints (+$5 CAD)</option>
            </select>
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </div>
        </div>
      {%- endfor -%}

      {%- comment %} Hidden inputs submitted with the product form as line item properties {%- endcomment -%}
      {%- for i in (1..tray_count) -%}
        <input type="hidden" name="properties[Tray {{ i }}]" id="nf-prop-{{ i }}-{{ section.id }}" form="{{ product_form_id }}" value="Magnet Tray">
      {%- endfor -%}
    </div>

    <script>
      (function () {
        var sid = {{ section.id | json }};
        var allVariants = {{ product.variants | json }};

        function getIdInput() {
          return document.querySelector('product-form .product-variant-id');
        }

        function syncColorHighlight() {
          var vsContainer = document.getElementById('variant-selects-' + sid);
          if (!vsContainer) return;
          // Remove existing highlights
          vsContainer.querySelectorAll('.product-form__input--pill label').forEach(function (lbl) {
            lbl.removeAttribute('data-nf-selected');
          });
          // Apply to checked radio's label
          var colorRadio = vsContainer.querySelector('.product-form__input--pill input:checked');
          if (colorRadio) {
            var lbl = colorRadio.nextElementSibling;
            if (lbl && lbl.tagName === 'LABEL') lbl.setAttribute('data-nf-selected', '');
          }
        }

        function syncTrays() {
          var idInput = getIdInput();
          if (!idInput) return;

          // Get current colour from the checked radio inside variant-selects.
          var vsContainer = document.getElementById('variant-selects-' + sid);
          var colorRadio = vsContainer ? vsContainer.querySelector('fieldset input:checked') : null;
          var color = colorRadio ? colorRadio.value : null;

          // Fallback: derive colour from whichever variant Dawn last set on idInput.
          if (!color) {
            var currentVariant = allVariants.find(function (v) {
              return v.id === parseInt(idInput.value, 10);
            });
            color = currentVariant ? currentVariant.option1 : null;
          }
          if (!color) return;

          // Tally paint trays and update line item property inputs.
          var traySelects = document.querySelectorAll('.nf-tray-select[data-section="' + sid + '"]');
          var paintCount = 0;
          traySelects.forEach(function (sel) {
            var prop = document.getElementById('nf-prop-' + sel.dataset.tray + '-' + sid);
            if (prop) prop.value = sel.value;
            if (sel.value.indexOf('Paint Tray') === 0) paintCount++;
          });

          // Find the matching variant.
          var variant = allVariants.find(function (v) {
            return v.option1 === color && v.option2 === String(paintCount);
          });
          if (!variant) return;

          // Update price display — replace only the number to preserve currency format.
          var priceBox = document.getElementById('price-' + sid);
          var priceEl = priceBox ? priceBox.querySelector('.price__regular .price-item--regular') : null;
          if (priceEl) {
            priceEl.textContent = priceEl.textContent.replace(/[\d,]+\.\d{2}/, (variant.price / 100).toFixed(2));
          }

          // Update the variant ID submitted with the cart form.
          idInput.value = variant.id;
          syncColorHighlight();
        }

        function attachListeners() {
          var idInput = getIdInput();

          // Tray dropdowns: sync on change and stop event from bubbling into
          // variant-selects (which would trigger an unwanted Dawn server fetch).
          document.querySelectorAll('.nf-tray-select[data-section="' + sid + '"]').forEach(function (sel) {
            sel.addEventListener('change', function (e) {
              e.stopPropagation();
              syncTrays();
            });
          });

          // Colour changes: Dawn fetches new HTML, swaps variant-selects, then
          // dispatches a 'change' event on idInput via updateVariantInputs().
          // We listen for that to re-sync paint count onto the new colour variant.
          if (idInput) {
            idInput.addEventListener('change', function () {
              setTimeout(function () { syncTrays(); syncColorHighlight(); }, 0);
            });
          }

          syncTrays();
          syncColorHighlight();
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', attachListeners);
        } else {
          attachListeners();
        }
      })();
    </script>
  {%- endif -%}
{%- endunless -%}
