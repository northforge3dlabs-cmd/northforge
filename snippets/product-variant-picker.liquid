{% comment %}
  Renders product variant-picker

  Accepts:
  - product: {Object} product object.
  - block: {Object} passing the block information.
  - product_form_id: {String} Id of the product form to which the variant picker is associated.
  Usage:
  {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id %}
{% endcomment %}
{%- unless product.has_only_default_variant -%}
  <variant-selects
    id="variant-selects-{{ section.id }}"
    data-section="{{ section.id }}"
    {{ block.shopify_attributes }}
  >
    {%- for option in product.options_with_values -%}
      {%- liquid
        assign swatch_count = option.values | map: 'swatch' | compact | size
        assign picker_type = block.settings.picker_type

        if swatch_count > 0 and block.settings.swatch_shape != 'none'
          if block.settings.picker_type == 'dropdown'
            assign picker_type = 'swatch_dropdown'
          else
            assign picker_type = 'swatch'
          endif
        endif
      -%}

      {%- if option.name == 'Paint Trays' -%}
        {%- comment %} Hidden — value driven by JS based on tray selectors below {%- endcomment -%}
        <div style="display:none" aria-hidden="true">
          <select
            id="Option-{{ section.id }}-{{ forloop.index0 }}"
            class="select__select"
            name="options[{{ option.name | escape }}]"
            form="{{ product_form_id }}"
          >
            {%- for value in option.values -%}
              <option
                value="{{ value | escape }}"
                {% if option.selected_value == value %}selected{% endif %}
              >{{ value | escape }}</option>
            {%- endfor -%}
          </select>
        </div>

      {%- elsif picker_type == 'swatch' -%}
        <fieldset class="js product-form__input product-form__input--swatch">
          <legend class="form__label">
            {{ option.name }}:
            <span data-selected-value>
              {{- option.selected_value -}}
            </span>
          </legend>
          {% render 'product-variant-options',
            product: product,
            option: option,
            block: block,
            picker_type: picker_type
          %}
        </fieldset>
      {%- elsif picker_type == 'button' -%}
        <fieldset class="js product-form__input product-form__input--pill">
          <legend class="form__label">{{ option.name }}</legend>
          {% render 'product-variant-options',
            product: product,
            option: option,
            block: block,
            picker_type: picker_type
          %}
        </fieldset>
      {%- else -%}
        <div class="product-form__input product-form__input--dropdown">
          <label class="form__label" for="Option-{{ section.id }}-{{ forloop.index0 }}">
            {{ option.name }}
          </label>
          <div class="select">
            {%- if picker_type == 'swatch_dropdown' -%}
              <span
                data-selected-value
                class="dropdown-swatch"
              >
                {% render 'swatch', swatch: option.selected_value.swatch, shape: block.settings.swatch_shape %}
              </span>
            {%- endif -%}
            <select
              id="Option-{{ section.id }}-{{ forloop.index0 }}"
              class="select__select"
              name="options[{{ option.name | escape }}]"
              form="{{ product_form_id }}"
            >
              {% render 'product-variant-options',
                product: product,
                option: option,
                block: block,
                picker_type: picker_type
              %}
            </select>
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}

    {%- comment %} Tray configuration — only rendered for products with a "Paint Trays" option {%- endcomment %}
    {%- assign has_paint_trays_option = false -%}
    {%- for option in product.options_with_values -%}
      {%- if option.name == 'Paint Trays' -%}
        {%- assign has_paint_trays_option = true -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_paint_trays_option -%}
      <div class="nf-tray-config" id="nf-tray-config-{{ section.id }}">
        <p class="form__label" style="margin-bottom:0.6rem;margin-top:2rem;">Tray Configuration</p>
        <p style="font-size:1.4rem;color:#666;margin-bottom:1.4rem;line-height:1.5;">
          Select the type for each of the 3 storage trays. Paint trays add $5 CAD each.
        </p>

        {%- for i in (1..3) -%}
          <div class="product-form__input product-form__input--dropdown" style="margin-bottom:1rem;">
            <label class="form__label" for="nf-tray-{{ i }}-{{ section.id }}">Tray {{ i }}</label>
            <div class="select">
              <select
                id="nf-tray-{{ i }}-{{ section.id }}"
                class="select__select nf-tray-select"
                data-tray="{{ i }}"
                data-section="{{ section.id }}"
              >
                <option value="Magnet Tray">Magnet Tray</option>
                <option value="GW Tray">GW Tray</option>
                <option value="Paint Tray — Vallejo / Army Painter">Paint Tray — Vallejo / Army Painter (+$5 CAD)</option>
                <option value="Paint Tray — Citadel Paints">Paint Tray — Citadel Paints (+$5 CAD)</option>
              </select>
              <span class="svg-wrapper">
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </div>
          </div>
        {%- endfor -%}

        {%- comment %} Hidden inputs submitted with the product form as line item properties {%- endcomment -%}
        <input type="hidden" name="properties[Tray 1]" id="nf-prop-1-{{ section.id }}" form="{{ product_form_id }}" value="Magnet Tray">
        <input type="hidden" name="properties[Tray 2]" id="nf-prop-2-{{ section.id }}" form="{{ product_form_id }}" value="Magnet Tray">
        <input type="hidden" name="properties[Tray 3]" id="nf-prop-3-{{ section.id }}" form="{{ product_form_id }}" value="Magnet Tray">
      </div>

      <script>
        (function () {
          var sid = {{ section.id | json }};
          var allVariants = {{ product.variants | json }};

          // Find the cart-form variant ID input — Dawn keeps this updated on colour changes.
          // It has class product-variant-id and lives inside the <product-form> element.
          function getIdInput() {
            return document.querySelector('product-form .product-variant-id');
          }

          function syncTrays() {
            var idInput = getIdInput();
            if (!idInput) return;

            // Derive current colour from whichever variant Dawn has already selected.
            var currentVariant = allVariants.find(function (v) {
              return v.id === parseInt(idInput.value, 10);
            });
            var color = currentVariant ? currentVariant.option1 : null;
            if (!color) return;

            // Tally paint trays and update property inputs.
            var traySelects = document.querySelectorAll('.nf-tray-select[data-section="' + sid + '"]');
            var paintCount = 0;
            traySelects.forEach(function (sel) {
              var prop = document.getElementById('nf-prop-' + sel.dataset.tray + '-' + sid);
              if (prop) prop.value = sel.value;
              if (sel.value.indexOf('Paint Tray') === 0) paintCount++;
            });

            // Keep hidden Paint Trays select in sync.
            var container = document.getElementById('variant-selects-' + sid);
            var paintSel = container ? container.querySelector('[name^="Paint Trays"]') : null;
            if (paintSel) paintSel.value = String(paintCount);

            // Find the target variant.
            var variant = allVariants.find(function (v) {
              return v.option1 === color && v.option2 === String(paintCount);
            });
            if (!variant) return;

            // Update price display — replace only the number to preserve the theme's currency format.
            var priceBox = document.getElementById('price-' + sid);
            var priceEl = priceBox ? priceBox.querySelector('.price__regular .price-item--regular') : null;
            if (priceEl) {
              priceEl.textContent = priceEl.textContent.replace(/[\d,]+\.\d{2}/, (variant.price / 100).toFixed(2));
            }

            // Update the variant ID submitted with the cart form.
            idInput.value = variant.id;
          }

          function attachListeners() {
            // Tray dropdowns: sync immediately on change.
            document.querySelectorAll('.nf-tray-select[data-section="' + sid + '"]').forEach(function (sel) {
              sel.addEventListener('change', syncTrays);
            });

            // Colour option changes: defer so Dawn's own handler updates idInput first,
            // then we re-sync the paint count on top of the newly selected colour variant.
            var container = document.getElementById('variant-selects-' + sid);
            if (container) {
              container.addEventListener('change', function (e) {
                if (e.target.classList.contains('nf-tray-select')) return; // handled above
                setTimeout(syncTrays, 0);
              });
            }

            syncTrays();
          }

          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', attachListeners);
          } else {
            attachListeners();
          }
        })();
      </script>
    {%- endif -%}

    <script type="application/json" data-selected-variant>
      {{ product.selected_or_first_available_variant | json }}
    </script>
  </variant-selects>
{%- endunless -%}
