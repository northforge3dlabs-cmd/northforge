{%- comment -%}
  Northforge Labs — Custom Order request form + file uploader
  Place this file at: sections/custom-order-form.liquid
  Then add the section to the "Custom 3D Printing" page in the theme customizer
  (or include it in a custom page template). It renders a native Shopify
  contact form (emails the store) followed by the DriveUploader drag & drop.

  IMPORTANT: after adding this section, remove the old #quote block + uploader
  iframe from the page body content so it isn't duplicated. This section already
  carries id="quote", so the hero "Get a Quote" button will still scroll here.
{%- endcomment -%}

<section id="quote" class="nf-quote" style="padding: 48px 24px; background: rgba(255,255,255,0.04); border-top: 1px solid rgba(255,255,255,0.08);">
  <div style="max-width: 640px; margin: 0 auto;">

    <h2 style="text-align: center; font-size: 2rem; margin-bottom: 12px;">{{ section.settings.heading }}</h2>
    <p style="text-align: center; opacity: 0.85; margin-bottom: 32px;">{{ section.settings.intro }}</p>

    {%- if form.posted_successfully? -%}
      <div id="nf-success" style="background: rgba(120,200,120,0.12); border: 1px solid rgba(120,200,120,0.4); border-radius: 6px; padding: 20px; text-align: center; margin-bottom: 24px;">
        <strong>Thanks — your request has been received!</strong><br>
        We'll review your details and get back to you within 24–48 hours with a quote.
        If you haven't dropped your files below yet, you can still do that now.
      </div>
      <script>document.getElementById('nf-success')&&document.getElementById('nf-success').scrollIntoView({behavior:'smooth',block:'center'});</script>
    {%- endif -%}

    {%- form 'contact', id: 'custom-order-form' -%}
      <input type="hidden" name="return_to" value="{{ request.path }}">
      {%- if form.errors -%}
        <div style="background: rgba(220,90,90,0.12); border: 1px solid rgba(220,90,90,0.4); border-radius: 6px; padding: 16px; margin-bottom: 20px;">
          Please check the highlighted fields: {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="nf-field">
        <label for="co-name">Name <span aria-hidden="true">*</span></label>
        <input type="text" id="co-name" name="contact[name]" value="{{ form.name }}" required>
      </div>

      <div class="nf-field">
        <label for="co-email">Email <span aria-hidden="true">*</span></label>
        <input type="email" id="co-email" name="contact[email]" value="{{ form.email }}" required>
      </div>

      <div class="nf-field">
        <label for="co-desc">Item / project description <span aria-hidden="true">*</span></label>
        <textarea id="co-desc" name="contact[Item or project description]" rows="3" required></textarea>
      </div>

      <div class="nf-field">
        <label for="co-material">Material &amp; colour</label>
        <input type="text" id="co-material" name="contact[Material and colour]" placeholder="e.g. grey resin, black PLA">
      </div>

      <div class="nf-row">
        <div class="nf-field">
          <label for="co-qty">Quantity</label>
          <input type="text" id="co-qty" name="contact[Quantity]" placeholder="e.g. 1">
        </div>
        <div class="nf-field">
          <label for="co-deadline">Desired deadline</label>
          <input type="text" id="co-deadline" name="contact[Desired deadline]" placeholder="e.g. by June 30">
        </div>
      </div>

      <div class="nf-field">
        <label for="co-shipping">Shipping address</label>
        <textarea id="co-shipping" name="contact[Shipping address]" rows="3" placeholder="Street, city, province, postal code — or note 'local pickup in Ontario'"></textarea>
      </div>

      <div class="nf-field">
        <label for="co-notes">Anything else?</label>
        <textarea id="co-notes" name="contact[body]" rows="2"></textarea>
      </div>

      <button type="submit" class="nf-submit">Send request</button>
    {%- endform -%}

    <div style="text-align: center; margin: 40px 0 12px;">
      <h3 style="font-size: 1.25rem; margin-bottom: 6px;">{{ section.settings.upload_heading }}</h3>
      <p style="opacity: 0.85; font-size: 0.95rem;">{{ section.settings.upload_intro }}</p>
    </div>

    <div style="max-width: 600px; margin: 0 auto;">
      <iframe
        src="{{ section.settings.uploader_url }}"
        title="Upload your files"
        loading="lazy"
        style="border: 0; width: 100%; height: 290px; border-radius: 6px;"></iframe>
      <p style="text-align: center; font-size: 0.85rem; opacity: 0.7; margin-top: 16px;">
        Drag &amp; drop your files above — STL, OBJ, images or PDFs. Large files welcome.
      </p>
    </div>

  </div>
</section>

<style>
  .nf-quote .nf-field { margin-bottom: 18px; text-align: left; }
  .nf-quote .nf-field label { display: block; font-size: 0.9rem; margin-bottom: 6px; opacity: 0.9; }
  .nf-quote .nf-field input,
  .nf-quote .nf-field textarea {
    width: 100%;
    box-sizing: border-box;
    padding: 10px 12px;
    border-radius: 6px;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.06);
    color: inherit;
    font: inherit;
  }
  .nf-quote .nf-field input:focus,
  .nf-quote .nf-field textarea:focus {
    outline: none;
    border-color: #c89858;
  }
  .nf-quote .nf-row { display: flex; gap: 16px; }
  .nf-quote .nf-row .nf-field { flex: 1; }
  .nf-quote .nf-submit,
  .nf-quote button.nf-submit {
    display: block;
    width: 100%;
    padding: 14px;
    margin-top: 8px;
    border: 0 !important;
    border-radius: 6px !important;
    background: #c89858 !important;
    color: #1a1a1a !important;
    font-weight: 700;
    font-size: 1rem;
    text-transform: none !important;
    letter-spacing: normal !important;
    cursor: pointer;
  }
  .nf-quote .nf-submit:hover,
  .nf-quote button.nf-submit:hover { background: #b9863f !important; opacity: 1; }
  @media (max-width: 540px) {
    .nf-quote .nf-row { flex-direction: column; gap: 0; }
  }
</style>

{% schema %}
{
  "name": "Custom order form",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Request a Quote" },
    { "type": "textarea", "id": "intro", "label": "Intro text", "default": "Tell us about your project and we'll get back to you within 24–48 hours with a written quote." },
    { "type": "text", "id": "upload_heading", "label": "Upload heading", "default": "Upload your files" },
    { "type": "textarea", "id": "upload_intro", "label": "Upload intro", "default": "Already have your model ready? Drop it below and reference it in your request above." },
    { "type": "text", "id": "uploader_url", "label": "DriveUploader embed URL", "default": "https://driveuploader.com/upload/PqATQuWUMa/embed/" }
  ],
  "presets": [
    { "name": "Custom order form" }
  ]
}
{% endschema %}
